{
  "manifest_version": 3,
  "name": "Quantbrowse AI",
  "version": "2.0.0",
  "description": "AI OS Shell — Shadow DOM injection, swarm coordination, and cross-tab orchestration.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quantbrowse AI"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "activeTab",
    "alarms",
    "bookmarks",
    "idle",
    "notifications",
    "scripting",
    "storage",
    "tabGroups",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "toggle-dashboard": {
      "suggested_key": {
        "default": "Alt+Shift+Q"
      },
      "description": "Toggle the Quantbrowse ambient dashboard"
    },
    "group-tabs": {
      "suggested_key": {
        "default": "Alt+Shift+G"
      },
      "description": "Run smart AI tab grouping"
    },
    "trigger-digest": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Send the daily digest now"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "csp_bypass_ruleset",
        "enabled": false,
        "path": "rules/csp_bypass.json"
      }
    ]
  }
}
