{
  "manifest_version": 3,
  "name": "Quantbrowse AI",
  "version": "2.1.0",
  "description": "AI OS Shell — Universal Web Clipper, Shadow DOM injection, swarm coordination, and cross-tab orchestration.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quantbrowse AI"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "content/clipper.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webNavigation",
    "declarativeNetRequest",
    "contextMenus",
    "clipboardWrite",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "csp_bypass_ruleset",
        "enabled": false,
        "path": "rules/csp_bypass.json"
      }
    ]
  }
}
