{
  "manifest_version": 3,
  "name": "Quantbrowse AI",
  "version": "2.0.0",
  "description": "AI OS Shell with ambient intelligence: usage dashboard, smart tab grouping, daily digest, AI bookmarks, productivity score, ecosystem redirect, Shadow DOM injection, and swarm coordination.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quantbrowse AI"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.reddit.com/*",
        "*://*.google.com/search*",
        "*://*.bing.com/*",
        "*://*.netflix.com/*",
        "*://*.spotify.com/*",
        "*://*.medium.com/*",
        "*://news.google.com/*",
        "*://*.amazon.com/*"
      ],
      "js": ["redirect-badge.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "bookmarks",
    "notifications",
    "alarms",
    "tabGroups",
    "history",
    "windows",
    "webNavigation",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "csp_bypass_ruleset",
        "enabled": false,
        "path": "rules/csp_bypass.json"
      }
    ]
  }
}
